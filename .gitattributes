# Normalize line endings on commit; check out with the platform's native style.
* text=auto eol=lf

# Binary assets: never normalize or diff as text.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary

# Generated / data files: keep out of GitHub's language stats and collapse in
# PR diffs by default.
bun.lock     linguist-generated=true
CHANGELOG.md linguist-generated=true

# Documentation site source: counts as docs, not a primary language.
docs/** linguist-documentation=true
